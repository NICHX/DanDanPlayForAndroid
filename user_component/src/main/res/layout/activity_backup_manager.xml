<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="com.xyoye.user_component.ui.activities.backup_manager.BackupManagerViewModel" />

        <variable
            name="viewModel"
            type="com.xyoye.user_component.ui.activities.backup_manager.BackupManagerViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/layout_bg_color"
        android:orientation="vertical">

        <include layout="@layout/layout_toolbar" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/background_item_corner"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/export_ll"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="2dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_backup_manager"
                            app:tint="@color/colorAccent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="导出配置"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="将设置和服务器信息导出为配置文件"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_right" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/background_item_corner"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/import_ll"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="2dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_restore_manager"
                            app:tint="@color/orange" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="导入配置"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="从配置文件恢复软件设置和服务器信息"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_right" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/background_item_corner"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/webdav_header_ll"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="2dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_webdav_cloud"
                            app:tint="@color/orange" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WebDAV自动备份"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="配置后自动上传备份至WebDAV服务器"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_right" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/webdav_enable_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            app:theme="@style/Theme.DanDanPlay.SwitchCompat" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/webdav_settings_ll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="服务器选择"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/server_mode_rg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/custom_mode_rb"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="自定义"
                                android:textColor="@color/text_black"
                                android:textSize="14sp" />

                            <RadioButton
                                android:id="@+id/existing_mode_rb"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="从已有服务器选择"
                                android:textColor="@color/text_black"
                                android:textSize="14sp" />
                        </RadioGroup>

                        <LinearLayout
                            android:id="@+id/custom_fields_ll"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/webdav_url_et"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/background_dialog_edit"
                                android:gravity="center_vertical"
                                android:hint="WebDAV服务器地址"
                                android:inputType="textUri"
                                android:maxLines="1"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:singleLine="true"
                                android:textColor="@color/text_black"
                                android:textColorHint="@color/text_gray"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/webdav_account_et"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/background_dialog_edit"
                                android:gravity="center_vertical"
                                android:hint="账号"
                                android:maxLines="1"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:singleLine="true"
                                android:textColor="@color/text_black"
                                android:textColorHint="@color/text_gray"
                                android:textSize="14sp" />

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <androidx.appcompat.widget.AppCompatEditText
                                    android:id="@+id/webdav_password_et"
                                    android:layout_width="match_parent"
                                    android:layout_height="44dp"
                                    android:background="@drawable/background_dialog_edit"
                                    android:gravity="center_vertical"
                                    android:hint="密码"
                                    android:inputType="textPassword"
                                    android:maxLines="1"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="80dp"
                                    android:singleLine="true"
                                    android:textColor="@color/text_black"
                                    android:textColorHint="@color/text_gray"
                                    android:textSize="14sp" />

                                <ImageView
                                    android:id="@+id/password_toggle_iv"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:layout_gravity="end"
                                    android:padding="14dp"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_input_visible" />
                            </FrameLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/existing_server_ll"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/background_dialog_edit"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="请选择WebDAV服务器"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp"
                                tools:text="My WebDAV Server" />

                            <TextView
                                android:id="@+id/select_server_tv"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/background_button_corner_gray"
                                android:gravity="center"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="选择"
                                android:textColor="@color/text_black"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="备份目录"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/webdav_dir_et"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/background_dialog_edit"
                            android:gravity="center_vertical"
                            android:hint="/NIplayer_backup"
                            android:maxLines="1"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:singleLine="true"
                            android:textColor="@color/text_black"
                            android:textColorHint="@color/text_gray"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="保留份数"
                                android:textColor="@color/text_black"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/keep_count_et"
                                android:layout_width="60dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/background_dialog_edit"
                                android:gravity="center"
                                android:inputType="number"
                                android:maxLines="1"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:singleLine="true"
                                android:textColor="@color/text_black"
                                android:textSize="14sp"
                                tools:text="5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="份"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/save_webdav_config_tv"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/background_button_corner_gray"
                                android:gravity="center"
                                android:text="保存设置"
                                android:textColor="@color/text_black"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/upload_now_tv"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/background_button_corner_gray"
                                android:gravity="center"
                                android:text="立即上传"
                                android:textColor="@color/text_black"
                                android:textSize="15sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="配置文件包含：显示隐藏文件、深色模式、常用目录、上次打开目录开关、播放器设置、字幕设置、视图模式、缩略图设置、服务器信息等"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</layout>